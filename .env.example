# ============================================================
# SentinelAI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in production values.
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ============================================================

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=sentinelai
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=sentinel_dev_password
REDIS_HOST=redis
REDIS_PORT=6379

# ── Elasticsearch ──────────────────────────────────────────
ELASTICSEARCH_HOST=http://elasticsearch:9200
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ── NATS JetStream ─────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Backend Application ────────────────────────────────────
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-openssl-rand-hex-32
JWT_SECRET_KEY=CHANGE-ME-jwt-secret-key-use-openssl-rand-hex-64
DEBUG=true

# ── CORS (JSON array of origins) ────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8080"]

# ── LLM Configuration ─────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=bjoernb/claude-opus-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── NVD Vulnerability Database ─────────────────────────────
NVD_API_KEY=

# ── SMTP / Email ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@sentinelai.local
SMTP_USE_TLS=true

# ── Admin Seed (first run only) ───────────────────────────
# Leave blank to have the application auto-generate a random password
# on first startup (recommended). The generated password will be printed
# once to stdout — record it immediately and change it after first login.
# Set this only when a predictable initial password is required (e.g. CI).
ADMIN_DEFAULT_EMAIL=admin@sentinelai.local
ADMIN_DEFAULT_PASSWORD=

# ── Panel ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Enrollment Service ─────────────────────────────────────
ENROLLMENT_CA_KEY_PASSWORD=

# ── GeoIP (for enrichment service) ─────────────────────────
GEOIP_DB_PATH=/app/data/geoip/GeoLite2-City.mmdb
